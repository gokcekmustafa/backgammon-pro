# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/db
JWT_SECRET=openssl rand -hex 32 ile uret
JWT_REFRESH_SECRET=openssl rand -hex 32 ile uret

# ── Server ──────────────────────────────────────────────────────────────
HTTP_PORT=3001
WS_PORT=3002
NODE_ENV=production
LOG_LEVEL=info
FRONTEND_URL=https://backgammon-pro.pages.dev
BACKEND_URL=https://api.backgammon-pro.example.com

# ── Rate Limit ──────────────────────────────────────────────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_PER_USER=200
RATE_LIMIT_PER_IP=300
CONCURRENT_SESSION_LIMIT=5

# ── Cache ───────────────────────────────────────────────────────────────
CACHE_TTL_DEFAULT=60000
CACHE_TTL_LEADERBOARD=30000
CACHE_TTL_SEASONS=30000
CACHE_TTL_PROFILE=60000
CACHE_TTL_TOURNAMENTS=30000
CACHE_TTL_ROOMS=10000
CACHE_TTL_TABLES=5000
