# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://backgammon:backgammon@localhost:5432/backgammon
POSTGRES_USER=backgammon
POSTGRES_DB=backgammon

# ── JWT ─────────────────────────────────────────────────────────────────
# Uret: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-to-another-random-secret-at-least-32-chars

# ── Server ──────────────────────────────────────────────────────────────
# Render/Railway otomatik PORT atar. HTTP_PORT=PORT ile ezilir.
PORT=
HTTP_PORT=3001
WS_PORT=3002
NODE_ENV=development
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=30000

# ── CORS ────────────────────────────────────────────────────────────────
# Frontend'in canli URL'i (Cloudflare Pages)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# ── Rate Limiting ───────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_PER_USER=200
RATE_LIMIT_PER_IP=300

# ── Security ────────────────────────────────────────────────────────────
CONCURRENT_SESSION_LIMIT=5
SUSPICIOUS_LOGIN_THRESHOLD=5
MIN_MOVE_TIME_MS=100

# ── Cache TTL (ms) ──────────────────────────────────────────────────────
CACHE_TTL_DEFAULT=60000
CACHE_TTL_LEADERBOARD=30000
CACHE_TTL_SEASONS=30000
CACHE_TTL_PROFILE=60000
CACHE_TTL_TOURNAMENTS=30000
CACHE_TTL_ROOMS=10000
CACHE_TTL_TABLES=5000

# ── Frontend (Next.js) ──────────────────────────────────────────────────
# Build sirasinda gomulur. Render URL'i deploy'dan sonra guncelle.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3002
